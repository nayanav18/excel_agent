{
  "manifest_version": 3,
  "name": "Qlik Capture",
  "version": "1.0",
 
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "downloads"
  ],
 
  "host_permissions": [
    "<all_urls>"
  ],
 
  "background": {
    "service_worker": "background.js"
  },
 
  "action": {
    "default_popup": "popup.html"
  }
}